<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>

<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.MenuButton?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.booktracker.controllers.AchievementController"
            prefHeight="720.0" prefWidth="1280.0"
            style="-fx-background-image: url('/com/booktracker/view/backgrounds/achievement.png'); -fx-background-size: cover;">

    <top>
        <HBox spacing="30" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-background-color: #004225;">
            <Label text="Home" style="-fx-text-fill: white; -fx-font-size: 18;"
                   onMouseClicked="#onHomeClicked"/>
            <Label text="Library" style="-fx-text-fill: white; -fx-font-size: 18;"
                   onMouseClicked="#onLibraryClicked"/>
            <Label text="Wishlist" style="-fx-text-fill: white; -fx-font-size: 18;"
                   onMouseClicked="#onWishlistClicked"/>
            <MenuButton style="-fx-background-color: #004225;">
                <graphic>
                    <Label text="Search" style="-fx-text-fill: white; -fx-font-size: 18;"/>
                </graphic>
                <items>
                    <MenuItem text="Search by Author/Title" onAction="#onSearchByAuthorTitle"
                              style="-fx-text-fill: #004225; -fx-font-size: 15;"/>
                    <MenuItem text="Search by Copy" onAction="#onSearchByCopy"
                              style="-fx-text-fill: #004225; -fx-font-size: 15;"/>
                </items>
            </MenuButton>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Sign Out" onAction="#onSignOutClicked"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-size: 15;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" alignment="TOP_CENTER" style="-fx-padding: 20;">
            <Label text="Your Achievements" style="-fx-font-size: 30px; -fx-text-fill: #004225; -fx-font-weight: bold;"/>
            <ListView fx:id="achievementListView" style="-fx-padding: 20;"/>
        </VBox>
    </center>

</BorderPane>
