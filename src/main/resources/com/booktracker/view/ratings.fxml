<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.Integer?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.MenuButton?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.booktracker.controllers.RatingController"
            prefHeight="720.0" prefWidth="1280.0"
            style="-fx-background-color: #ADFFA4">

    <top>
        <HBox spacing="30" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-background-color: #004225;">
            <Label text="Home" style="-fx-text-fill: white; -fx-font-size: 18;"
                   onMouseClicked="#onHomeClicked"/>
            <Label text="Library" style="-fx-text-fill: white; -fx-font-size: 18;"
                   onMouseClicked="#onLibraryClicked"/>
            <Label text="Wishlist" style="-fx-text-fill: white; -fx-font-size: 18;"
                   onMouseClicked="#onWishlistClicked"/>
            <MenuButton style="-fx-background-color: #004225;">
                <graphic>
                    <Label text="Search" style="-fx-text-fill: white; -fx-font-size: 18;"/>
                </graphic>
                <items>
                    <MenuItem text="Search by Author/Title" onAction="#onSearchByAuthorTitle"
                              style="-fx-text-fill: #004225; -fx-font-size: 15;"/>
                    <MenuItem text="Search by Copy" onAction="#onSearchByCopy"
                              style="-fx-text-fill: #004225; -fx-font-size: 15;"/>
                </items>
            </MenuButton>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Sign Out" onAction="#onSignOutClicked"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-size: 15;"/>
        </HBox>
    </top>

    <center>
        <ListView fx:id="ratingsListView" style="-fx-padding: 20; -fx-background-color: #ADFFA4"/>
    </center>

    <bottom>
        <HBox spacing="30" alignment="CENTER" style="-fx-padding: 15;">
            <Button text="Add Rating" onAction="#onAddRating"
                    style="-fx-background-color: #004225; -fx-text-fill: #FFFFFF;"/>
            <TextField fx:id="addRating" promptText="Enter Title"/>
            <ComboBox fx:id="starsField" promptText="★">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <Integer fx:value="1"/>
                        <Integer fx:value="2"/>
                        <Integer fx:value="3"/>
                        <Integer fx:value="4"/>
                        <Integer fx:value="5"/>
                    </FXCollections>
                </items>
            </ComboBox>
            <TextArea fx:id="addReview" promptText="Tell about your opinion..." prefWidth="400"/>
        </HBox>
    </bottom>
</BorderPane>
