<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.booktracker.controllers.SignUpController"
            prefHeight="720.0" prefWidth="1280.0">
    <top>
        <VBox alignment="CENTER" spacing="10">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Sign Up To Book Tracker">
                <font>
                    <Font size="24"/>
                </font>
            </Label>
        </VBox>
    </top>

    <!-- Két hasábos regisztrációs űrlap -->
    <center>
        <GridPane hgap="20" vgap="15">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" prefWidth="150"/>
                <ColumnConstraints halignment="LEFT" prefWidth="200"/>
                <ColumnConstraints halignment="RIGHT" prefWidth="150"/>
                <ColumnConstraints halignment="LEFT" prefWidth="200"/>
            </columnConstraints>

            <!-- Első sor -->
            <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="usernameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Password:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <PasswordField fx:id="passwordField" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <!-- Második sor -->
            <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="First Name:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            <TextField fx:id="firstNameField" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

            <!-- Harmadik sor -->
            <Label text="Last Name:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="lastNameField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Gender:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
            <ComboBox fx:id="genderField" GridPane.rowIndex="2" GridPane.columnIndex="3">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Male"/>
                        <String fx:value="Female"/>
                        <String fx:value="Other"/>
                    </FXCollections>
                </items>
            </ComboBox>

            <!-- Negyedik sor -->
            <Label text="Birth Date:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <DatePicker fx:id="birthDateField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        </GridPane>
    </center>

    <!-- Alul Sign Up gomb, link és vissza gomb -->
    <bottom>
        <HBox spacing="20" alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Button text="← Return" fx:id="returnButton" onAction="#onReturnClicked"/>
            <Button text="Sign Up" fx:id="signUpButton" onAction="#onSignUpClicked"/>
            <Label text="You already have an account?"/>
            <Hyperlink text="Sign in" fx:id="signInLink" onAction="#onSignInLinkClicked"/>
        </HBox>
    </bottom>
</BorderPane>
