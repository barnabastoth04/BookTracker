<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.booktracker.controllers.UserController"
            prefHeight="720.0" prefWidth="1280.0"
            style="-fx-background-color: #ADFFA4">

    <top>
        <HBox spacing="30" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-background-color: #004225;">
            <Label text="Home" style="-fx-text-fill: white; -fx-font-size: 18;"
                   onMouseClicked="#onHomeClicked"/>
            <Label text="Library" style="-fx-text-fill: white; -fx-font-size: 18;"
                   onMouseClicked="#onLibraryClicked"/>
            <Label text="Wishlist" style="-fx-text-fill: white; -fx-font-size: 18;"
                   onMouseClicked="#onWishlistClicked"/>
            <MenuButton style="-fx-background-color: #004225;">
                <graphic>
                    <Label text="Search" style="-fx-text-fill: white; -fx-font-size: 18;"/>
                </graphic>
                <items>
                    <MenuItem text="Search by Author/Title" onAction="#onSearchByAuthorTitle"
                              style="-fx-text-fill: #004225; -fx-font-size: 15;"/>
                    <MenuItem text="Search by Copy" onAction="#onSearchByCopy"
                              style="-fx-text-fill: #004225; -fx-font-size: 15;"/>
                </items>
            </MenuButton>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Sign Out" onAction="#onSignOutClicked"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-size: 15;"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="20">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <Label fx:id="welcomeLabel" style="-fx-font-size: 60px; -fx-font-weight: bold;
                   -fx-text-fill: #FFFFFF; -fx-effect: dropshadow(three-pass-box, #004225, 15, 0, 0, 0);"/>

            <HBox spacing="25" alignment="CENTER">
                <children>
                    <Button text="Readings" onAction="#onReadingsClicked" prefWidth="150"
                            style="-fx-background-color: #004225; -fx-font-size: 18; -fx-text-fill: #FFFFFF;"/>
                    <Button text="Ratings" onAction="#onRatingsClicked" prefWidth="150"
                            style="-fx-background-color: #004225; -fx-font-size: 18; -fx-text-fill: #FFFFFF;"/>
                    <Button text="Achievements" onAction="#onAchievementsClicked" prefWidth="150"
                            style="-fx-background-color: #004225; -fx-font-size: 18; -fx-text-fill: #FFFFFF;"/>
                    <Button text="Statistics" onAction="#onStatisticsClicked" prefWidth="150"
                            style="-fx-background-color: #004225; -fx-font-size: 18; -fx-text-fill: #FFFFFF;"/>
                </children>
            </HBox>

            <GridPane alignment="CENTER_LEFT" hgap="20" vgap="15">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
                <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-font-size: 20px; -fx-text-fill: #004225;"/>
                <Label fx:id="nameLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"
                       style="-fx-font-size: 20px; -fx-text-fill: #004225; -fx-font-weight: bold;"/>

                <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-font-size: 20px; -fx-text-fill: #004225;"/>
                <Label fx:id="emailLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"
                       style="-fx-font-size: 20px; -fx-text-fill: #004225; -fx-font-weight: bold;"/>

                <Label text="Birthdate:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="-fx-font-size: 20px; -fx-text-fill: #004225;"/>
                <Label fx:id="birthDateLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"
                       style="-fx-font-size: 20px; -fx-text-fill: #004225; -fx-font-weight: bold;"/>
            </GridPane>

            <VBox spacing="10" alignment="CENTER_LEFT">
                <children>
                    <Label text="Reading log:" style="-fx-font-size: 16px; -fx-text-fill: #004225; -fx-font-weight: bold;"/>

                    <HBox spacing="10">
                        <children>
                            <DatePicker fx:id="readingDatePicker"/>
                            <Button text="I have read on this day" onAction="#onSaveReadingClicked"
                                    style="-fx-background-color: #004225; -fx-text-fill: #FFFFFF;"/>
                        </children>
                    </HBox>
                </children>
            </VBox>
        </VBox>
    </center>
</BorderPane>
